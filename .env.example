# IFDS — Required API Keys
IFDS_POLYGON_API_KEY=your_polygon_key
IFDS_FMP_API_KEY=your_fmp_key
IFDS_FRED_API_KEY=your_fred_key
IFDS_UW_API_KEY=your_unusual_whales_key

# Telegram Alerts (optional)
IFDS_TELEGRAM_BOT_TOKEN=your_telegram_bot_token
IFDS_TELEGRAM_CHAT_ID=your_telegram_chat_id

# Runtime (optional)
IFDS_ASYNC_ENABLED=true
IFDS_CACHE_ENABLED=true
IFDS_CACHE_DIR=data/cache

# Tuning Overrides (optional)
IFDS_ACCOUNT_EQUITY=100000
IFDS_RISK_PER_TRADE_PCT=1.0
IFDS_MAX_POSITIONS=8
IFDS_CIRCUIT_BREAKER_LIMIT=5.0
IFDS_OUTPUT_DIR=output
IFDS_LOG_DIR=logs
